{
  "name": "Axiom Music",
  "description": "Axiom's Telegram Music Player Bot, written in Python with Pyrogram and Py-Tgcalls.",
  "logo": "https://files.catbox.moe/cudd9u.jpg",
  "keywords": [
    "python3",
    "telegram",
    "bot",
    "MusicBot",
    "telegram-bot",
    "pyrogram"
  ],
  "env": {
    "API_ID": {
      "description": "Get this value from https://my.telegram.org",
      "value": "123456",
      "required": true
    },
    "API_HASH": {
      "description": "Get this value from https://my.telegram.org",
      "value": "your_api_hash",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "A Bot's token from Botfather",
      "value": "123456789:your_bot_token",
      "required": true
    },
    "MONGO_DB_URI": {
      "description": "Get a mongodb url from https://cloud.mongodb.com.",
      "value": "mongodb+srv://username:password@cluster0.example.mongodb.net/?retryWrites=true&w=majority",
      "required": true
    },
    "OWNER_ID": {
      "description": "The user id of user whom you would like to add as OWNER.from @vcmnvbot on Telegram.",
      "value": "123456789",
      "required": true
    },
    "SUPPORT_CHANNEL": {
      "description": "Axiom channel link",
      "value": "https://t.me/AxiomBots",
      "required": true
    },
    "SUPPORT_CHAT": {
      "description": "Add AxiomChat group & support group Link",
      "value": "https://t.me/manavkiduniya",
      "required": true
    },
    "STRING_SESSION": {
      "description": "A Pyrogram String Session from telegram.tools .",
      "value": "your_pyrogram_string_session",
      "required": true
    },
    "HEROKU_API_KEY": {
      "description": "Your Heroku account's API key",
      "value": "",
      "required": false
    },
    "HEROKU_APP_NAME": {
      "description": "Your heroku app name",
      "value": "",
      "required": false
    },
    "LOGGER_ID": {
      "description": "Your Log Group ID, add your bot and promote as an admin with full rights!. Channel ki id mat daal dena bsdk.",
      "value": "-1001234567890",
      "required": true
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    },
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest.git"
    }
  ],
  "stack": "container"
}
